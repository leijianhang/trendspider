# 服务器配置
PORT=3001
NODE_ENV=development

# 数据源配置
# Tushare Token (可选，用于获取专业数据)
TUSHARE_TOKEN=your_token_here

# Redis配置 (可选，用于缓存)
REDIS_HOST=localhost
REDIS_PORT=6379

# API限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

HUNTER_DB_HOST=192.168.1.78
HUNTER_DB_PORT=3306
HUNTER_DB_NAME=hunter_db
HUNTER_DB_USER=hunter
HUNTER_DB_CONNECT_TIMEOUT_MS=3000
HUNTER_DB_QUERY_TIMEOUT_MS=3500

APOLLO_TAOS_REST_URL=http://192.168.1.48:6041/rest/sql
APOLLO_TAOS_DATABASE=apollo_db
APOLLO_TAOS_USER=apollo
APOLLO_TAOS_TIMEOUT_MS=6000

HUNTER_TAOS_REST_URL=http://192.168.1.48:6041/rest/sql
HUNTER_TAOS_DATABASE=hunter_db
HUNTER_TAOS_USER=hunter
HUNTER_TAOS_TIMEOUT_MS=6000
